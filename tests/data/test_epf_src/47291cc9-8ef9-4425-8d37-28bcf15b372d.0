#Область ОбработчикиСобытийФормы

&НаСервере
Процедура ПриСозданииНаСервере(Отказ, ОбработкаСтандартная)
	
	О = РеквизитФормыВЗначение(""Объект"");
	
	АвтоЗаголовок = Ложь;
	Заголовок = ""Изменение варианта """""" + Параметры.ВариантПредставление + """""""";
	
	КомпоновщикНастроек.Инициализировать(Новый ИсточникДоступныхНастроекКомпоновкиДанных(Параметры.СхемаАдрес));
	КомпоновщикНастроек.ЗагрузитьНастройки(Параметры.Вариант);
	
	Элементы.СтраницыНастроек.ТекущаяСтраница = Элементы.СтраницаПолейВыбора;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиСобытийЭлементовТаблицыФормыПараметрыВывода

&НаКлиенте
Процедура КомпоновщикНастроекНастройкиПараметрыВывода_ПриИзменении(Элемент)
	
	Строка = Элемент.ТекущиеДанные;
	ИдентификаторПараметра = ""Заголовок"";
	
	Если Строка <> Неопределено И Строка.Свойство(""Параметр"") И Строка.Параметр = ИдентификаторПараметра Тогда
		
		КомпоновщикНастроек.Настройки.ДополнительныеСвойства.Вставить(""ЗаголовокУстановленИнтерактивно"", 
			ЗначениеЗаполнено(Строка.Значение));
			
	КонецЕсли;
	
КонецПроцедуры

#КонецОбласти

#Область ОбработчикиКомандФормы

&НаСервере
Процедура ИзмененияУдалитьНаСервере()
	
	О = РеквизитФормыВЗначение(""Объект"");
	
	// Удалим настройки варианта из настроек
	О.ДокументыСводка_ВариантНастройки_Удалить(Параметры.СхемаИмя, Параметры.ВариантИмя);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзмененияУдалить(Команда)
	
	ИзмененияУдалитьНаСервере();
	
	ЗакрытиеРезСт = Новый Структура;
	ЗакрытиеРезСт.Вставить(""СхемаИмя""  );
	ЗакрытиеРезСт.Вставить(""ВариантИмя"");
	
	ЗаполнитьЗначенияСвойств(ЗакрытиеРезСт, Параметры);
	
	Закрыть(ЗакрытиеРезСт);
	
КонецПроцедуры

&НаСервере
Процедура ИзмененияДобавитьНаСервере()
	
	О = РеквизитФормыВЗначение(""Объект"");
	
	// Установим настройки варианта в настройки
	О.ДокументыСводка_ВариантНастройки_Установить(Параметры.СхемаИмя, Параметры.ВариантИмя, КомпоновщикНастроек.Настройки);
	
КонецПроцедуры

&НаКлиенте
Процедура ИзмененияДобавить(Команда)
	
	ИзмененияДобавитьНаСервере();
	
	ЗакрытиеРезСт = Новый Структура;
	ЗакрытиеРезСт.Вставить(""СхемаИмя""  );
	ЗакрытиеРезСт.Вставить(""ВариантИмя"");
	
	ЗаполнитьЗначенияСвойств(ЗакрытиеРезСт, Параметры);
	
	Закрыть(ЗакрытиеРезСт);
	
КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

&НаКлиенте
Процедура ПоляГруппировкиНедоступны()
	
	Элементы.СтраницыПолейГруппировки.ТекущаяСтраница = Элементы.НедоступныеНастройкиПолейГруппировки;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбранныеПоляДоступны(ЭлементСтруктуры)
	
	Если КомпоновщикНастроек.Настройки.НаличиеВыбораУЭлемента(ЭлементСтруктуры) Тогда
		
		ЛокальныеВыбранныеПоля = Истина;
		Элементы.СтраницыПолейВыбора.ТекущаяСтраница = Элементы.НастройкиВыбранныхПолей;
		
	Иначе
		
		ЛокальныеВыбранныеПоля = Ложь;
		Элементы.СтраницыПолейВыбора.ТекущаяСтраница = Элементы.ОтключенныеНастройкиВыбранныхПолей;
		
	КонецЕсли;
	
	Элементы.ЛокальныеВыбранныеПоля.ТолькоПросмотр = Ложь;
	
КонецПроцедуры

&НаКлиенте
Процедура ВыбранныеПоляНедоступны()
	
	ЛокальныеВыбранныеПоля = Ложь;
	Элементы.ЛокальныеВыбранныеПоля.ТолькоПросмотр = Истина;
	Элементы.СтраницыПолейВыбора.ТекущаяСтраница = Элементы.НедоступныеНастройкиВыбранныхПолей;
	
КонецПроцедуры

&НаКлиенте
Процедура ОтборДоступен(ЭлементСтруктуры)
	
	Если КомпоновщикНастроек.Настройки.НаличиеОтбораУЭлемента(ЭлементСтруктуры) Тогда
		
		ЛокальныйОтбор = Истина;
		Элементы.СтраницыОтбора.ТекущаяСтраница = Элементы.НастройкиОтбора;
		
	Иначе
		
		ЛокальныйОтбор = Ложь;
		Элементы.СтраницыОтбора.ТекущаяСтраница = Элементы.ОтключенныеНастройкиОтбора;
		
	КонецЕсли;
	
	Элементы.ЛокальныйОтбор.ТолькоПросмотр = Ложь;
	
КонецПроцедуры

